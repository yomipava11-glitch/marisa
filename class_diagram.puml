@startuml ClassDiagram

skinparam classAttributeIconSize 0

class Profil {
    + id : UUID
    + nom : String
    + email : String
    + avatar_url : String
    + role : String
    + updateProfile()
    + getStatistiques()
}

class Tache {
    + id : UUID
    + createur_id : UUID
    + titre : String
    + description : String
    + date_debut : Date
    + date_fin : Date
    + statut : String
    + est_collectif : Boolean
    + prioritaire : Boolean
    + calculateGlobalProgress()
    + generateAiAnalysis()
}

class SousTache {
    + id : UUID
    + tache_id : UUID
    + assigne_a : UUID
    + titre : String
    + statut : String
    + date_debut : Date
    + date_fin : Date
    + toggleStatus()
    + assignUser(userId)
}

class MembreTache {
    + id : UUID
    + tache_id : UUID
    + utilisateur_id : UUID
    + role : String
    + statut : String
    + updateRole(newRole)
    + updateStatus(newStatus)
}

class JournalOperation {
    + id : UUID
    + tache_id : UUID
    + utilisateur_id : UUID
    + action : String
    + date : Date
    + createLog()
}

class Message {
    + id : UUID
    + tache_id : UUID
    + utilisateur_id : UUID
    + contenu : String
    + created_at : Date
}

Profil "1" -- "*" Tache : crée (createur_id) >
Profil "1" -- "*" MembreTache : est membre de >
Profil "1" -- "*" SousTache : est assigné à >
Profil "1" -- "*" JournalOperation : écrit >

Tache "1" *-- "*" SousTache : contient >
Tache "1" *-- "*" MembreTache : a pour membres >
Tache "1" *-- "*" JournalOperation : possède historique >
Tache "1" *-- "*" Message : possède discussion >


@enduml
